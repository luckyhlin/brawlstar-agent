# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
.uv-cache-local/

# Jupyter checkpoints
.ipynb_checkpoints/

# Emulator & SDK (30GB, dead end — DEC-003/004)
emulator/

# Raw & processed media (videos, frames, screenshots — 3.3GB)
capture/

# Datasets (cropped frames, character refs, perception output — 104MB)
datasets/

# SQLite database (collected API data)
data/

# Model weights & checkpoints
models/*.pt
models/*.pth
models/*.onnx
models/*.bin
models/*.h5
models/*.lgb.txt
# Meta JSON pairs with the gitignored binaries; phase4 variants embed the
# full player_history_encoded lookup (~370 MB each) — never commit.
models/*.meta.json
*.pkl
*.npy

# Transient DB transfer chunks (e.g. for chunked rsync to droplet); 250MB each
tmp_db_chunks/

# Logs
logs/

# Editor / tool local settings
.claude/
.codex
.cursor/mcp.json

# OS
.DS_Store
Thumbs.db

# API example responses (large, regenerable)
docs/api-examples/

# env file
*.env
